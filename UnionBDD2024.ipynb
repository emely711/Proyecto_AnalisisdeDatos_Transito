import pandas as pd
import numpy as np
import os
import re
import random

# CONFIGURACIÓN DE ARCHIVOS Y PERIODOS

CONFIGURACION_ARCHIVOS = {
    "2024_AGOSTO_DICIEMBRE": {
        "nombre_archivo": "BDD_2024_AGOSTO_DICIEMBRE.xlsx",
        "hoja": "BDD_2024"
    },
    "2025_ENERO_JUNIO": {
        "nombre_archivo": "BDD_2025_ENERO_JUNIO.xlsx",
        "hoja": "BDD_2025"
    },
    "2025_JULIO_DICIEMBRE": {
        "nombre_archivo": "BDD_2025_JULIO_DICIEMBRE.xlsx",
        "hoja": "BDD_2025"
    }
}

ARCHIVO_SALIDA_FINAL = "BDD_CONSOLIDADO_40_COLUMNAS_SUCIAS.xlsx"

def transformar_a_40_columnas_sucias(df_original, periodo_etiqueta):
    # Nombres alterados de las 10 columnas base para activar el Column Renamer en KNIME
    mapeo_sucio_columnas = {
        'ROWID': 'ID_registro_FALSA',
        'SINIESTROS': 'Nro_Siniestro_XYZ',
        'ENTE_DE_CONTROL': 'E_Control_Reg',
        'PROVINCIA': 'Dpto_Provincia',
        'CANTON': 'Canton_Geo',
        'PARROQUIA': 'Loc_Parroquia',
        'DIRECCION': 'Direcc_Siniestro',
        'ZONA_PLANIFICACION': 'Z_Planific',
        'ZONA': 'Tipo_Zona',
        'ID_DE_LA_VIA': 'Via_Codigo'
    }
    
    columnas_fijas = [c for c in mapeo_sucio_columnas.keys() if c in df_original.columns]
    df_base = df_original[columnas_fijas].copy()
    df_base.rename(columns={c: mapeo_sucio_columnas[c] for c in columnas_fijas}, inplace=True)
    
    num_filas = len(df_base)
    opciones_vacias = [np.nan, "NULL", "N/A", "   ", "?", "sin_dato"]
    
    # Inyectar campos vehiculares y descriptivos
    df_base['Placa_Veh_TEXTO'] = [random.choice([f"PBA-{random.randint(1000,9999)}", f"GBA0{random.randint(100,999)}", "   ", "?"]) for _ in range(num_filas)]
    df_base['Clase_Veh_VAL'] = [random.choice(["AUTOMOVIL***", "  motocicleta  ", "CAMION//REG", "CAMIONETA", "NULL"]) for _ in range(num_filas)]
    df_base['Causa_Probable_Siniestro'] = [random.choice(["Imprudencia_Conductor", "EXCESO_VELOCIDAD//", "S/D", "Embriaguez_##"]) for _ in range(num_filas)]
    df_base['Tipo_Servicio_Veh'] = [random.choice(["PÚBLICO_M", "  particular  ", "ESTATAL", "N/A"]) for _ in range(num_filas)]
    
    # Separar Fecha y Hora en formatos de texto corrupto para activar String to Date&Time
    df_base['FECHA_REGISTRO_TEXTO'] = [f"2024/{random.randint(8,12):02d}/{random.randint(1,28):02d}" if "2024" in periodo_etiqueta else f"2025/{random.randint(1,12):02d}/{random.randint(1,28):02d}" for _ in range(num_filas)]
    df_base['HORA_REGISTRO_TEXTO'] = [f"{random.randint(0,23):02d}:{random.randint(0,59):02d}:{random.randint(0,59):02d}" for _ in range(num_filas)]
    
    # Inyectar texto base con inconsistencias de formato
    if 'E_Control_Reg' in df_base.columns:
        df_base['E_Control_Reg'] = df_base['E_Control_Reg'].astype(str).apply(lambda x: " [ANT]-Nacional_PROV " if "ANT" in x.upper() else " ##CTE--REGIONAL## " if "CTE" in x.upper() else "S/D")
    if 'Dpto_Provincia' in df_base.columns:
        df_base['Dpto_Provincia'] = df_base['Dpto_Provincia'].astype(str).apply(lambda x: "  pichincha__2024" if "PICHINCHA" in x.upper() else " guayas_C_M " if "GUAYAS" in x.upper() else "desconocido")
    if 'Canton_Geo' in df_base.columns:
        df_base['Canton_Geo'] = df_base['Canton_Geo'].astype(str).apply(lambda x: "UIO-D.M.Q." if "QUITO" in x.upper() else x)

    # Procesar los 7 grupos del desunpivot (Melt)
    grupos = ['EDAD', 'SEXO', 'CASCO', 'CINTURON', 'PARTICIPANTE', 'CONDICION', 'TIPO_ACC']
    col_pivote_sucia = 'ID_registro_FALSA' if 'ROWID' in df_original.columns else 'Nro_Siniestro_XYZ'
    
    for prefijo in grupos:
        columnas_grupo = [c for c in df_original.columns if re.match(rf'^{prefijo}_\d+', c)]
        
        if columnas_grupo:
            valid_id_vars = [c for c in columnas_fijas if c in df_original.columns]
            df_melt = df_original.melt(
                id_vars=valid_id_vars, 
                value_vars=columnas_grupo, 
                var_name=f'{prefijo}_ID', 
                value_name=f'{prefijo}_VALOR'
            )
            col_original_pivote = 'ROWID' if 'ROWID' in df_original.columns else 'SINIESTROS'
            if col_original_pivote in df_melt.columns:
                df_melt.rename(columns={col_original_pivote: col_pivote_sucia}, inplace=True)
            
            df_melt[f'{prefijo}_ID'] = df_melt[f'{prefijo}_ID'].astype(str).str.extract(r'(\d+)')[0].astype(float)
            
            if prefijo == 'TIPO_ACC':
                df_melt[f'{prefijo}_VALOR'] = df_melt[f'{prefijo}_VALOR'].astype(str).apply(lambda x: "  CHoQUe***  " if "CHOQUE" in x.upper() else "atropello //" if "ATRO" in x.upper() else "  pérdida_pista## " if "PISTA" in x.upper() else x)
            elif prefijo == 'EDAD':
                df_melt[f'{prefijo}_VALOR'] = df_melt[f'{prefijo}_VALOR'].apply(lambda x: str(random.randint(15, 80)) if str(x) != 'nan' and random.random() < 0.3 else x)
            else:
                df_melt[f'{prefijo}_VALOR'] = df_melt[f'{prefijo}_VALOR'].astype(str).apply(lambda x: " MASC_//_1 " if "MASC" in x.upper() else " fem_##_2 " if "FEM" in x.upper() else "???")
            
            if not df_melt.empty and col_pivote_sucia in df_melt.columns:
                df_melt_unique = df_melt.drop_duplicates(subset=[col_pivote_sucia])
                df_base = pd.merge(df_base, df_melt_unique[[col_pivote_sucia, f'{prefijo}_ID', f'{prefijo}_VALOR']], on=col_pivote_sucia, how='left')
        else:
            df_base[f'{prefijo}_ID'] = 0.0
            df_base[f'{prefijo}_VALOR'] = "N/A_SYSTEM"

    # Agregar Nombres de personas implicadas sucios
    nombres_ficiticios = ["JUAN ARTIeGA", " mAria_loPEz ", "carlos**Mendoza", "Ana_Maria_S", "  ", "NULL"]
    df_base['Nombre_Implicado_TEXTO'] = [random.choice(nombres_ficiticios) for _ in range(num_filas)]

    # Completar exactamente hasta las 40 columnas con relleno
    columnas_actuales = len(df_base.columns)
    columnas_faltantes = 40 - columnas_actuales
    
    if columnas_faltantes > 0:
        for i in range(1, columnas_faltantes + 1):
            df_base[f'Col_Relleno_{i}'] = [random.choice(opciones_vacias) for _ in range(num_filas)]
    elif columnas_faltantes < 0:
        df_base = df_base.iloc[:, :40]

    df_base['PERIODO_ORIGEN'] = periodo_etiqueta
    return df_base

# EJECUCIÓN PRINCIPAL

def ejecutar_proceso_maestro():
    dfs_consolidados = []
    
    for etiqueta, info in CONFIGURACION_ARCHIVOS.items():
        nombre_arch = info["nombre_archivo"]
        nombre_hoja = info["hoja"]
        
        if os.path.exists(nombre_arch):
            print(f"Leyendo archivo real: {nombre_arch} (Hoja: {nombre_hoja})...")
            try:
                df_raw = pd.read_excel(nombre_arch, sheet_name=nombre_hoja)
            except Exception as e:
                print(f"Error al leer {nombre_arch}: {e}")
                continue
        else:
            print(f"Advertencia: No se encontró el archivo '{nombre_arch}' en el directorio actual. Asegúrate de colocarlo junto a este script.")
            continue
            
        if 'ROWID' not in df_raw.columns:
            df_raw['ROWID'] = [f"Row_{etiqueta}_{i}" for i in range(len(df_raw))]
            
        df_transformado = transformar_a_40_columnas_sucias(df_raw, etiqueta)
        dfs_consolidados.append(df_transformado)
        print(f"  [OK] Periodo {etiqueta} procesado correctamente ({len(df_transformado)} filas).")

    if dfs_consolidados:
        df_final = pd.concat(dfs_consolidados, ignore_index=True, sort=False)
        df_final = df_final.iloc[:, :40]
        
        df_final.to_excel(ARCHIVO_SALIDA_FINAL, sheet_name="CONSOLIDADO_40_COL", index=False)
        print(f"\n==================================================")
        print(f"¡CONSOLIDACIÓN FINALIZADA CON ÉXITO!")
        print(f"Archivo de salida generado: {ARCHIVO_SALIDA_FINAL}")
        print(f"Dimensiones totales: {df_final.shape[0]} filas x {df_final.shape[1]} columnas.")
        print(f"==================================================")
    else:
        print("\nNo se pudo procesar ningún archivo. Verifica que los nombres de los excels coincidan exactamente con la configuración.")

ejecutar_proceso_maestro()
